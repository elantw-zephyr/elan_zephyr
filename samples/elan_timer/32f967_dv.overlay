#include <elan/32f967_dv_priv.dtsi>

/ {
	aliases {
		led0 = &led0;
		led1 = &led1;
	};

	leds {
		compatible = "gpio-leds";
		
		led0: led_0 {
			gpios = <&gpioa 3 GPIO_ACTIVE_HIGH>;
			label = "LED 0";
		};

		led1: led_1 {
			gpios = <&gpioa 4 GPIO_ACTIVE_HIGH>;
			label = "LED 1";
		};
	};
};

&gpioa {
	status = "okay";
};

